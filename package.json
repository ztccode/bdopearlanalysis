{
  "name": "bdo-pearl-shop-analysis",
  "version": "2.0.0-enterprise",
  "description": "Análise profissional de custo-benefício da Loja de Pérolas do Black Desert Online - Enterprise Edition",
  "author": "ztccode",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "concurrently \"vite --host 0.0.0.0 --port 5173\" \"tsx watch src/server/index.ts\"",
    "build": "vite build && tsc --noEmit && tsx build-server.ts",
    "start": "NODE_ENV=production node dist/server.js",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "check": "tsc --noEmit && eslint . --ext .ts,.tsx",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "type-check": "tsc --noEmit --skipLibCheck",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage --reporter=text --reporter=html",
    "db:push": "drizzle-kit push:pg",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate:pg",
    "seed": "tsx src/server/db/seed.ts",
    "validate": "pnpm type-check && pnpm lint && pnpm test"
  },
