# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/bdo_pearl
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=bdo_pearl

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET=your-super-secret-key-minimum-32-characters-required-for-production
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-minimum-32-characters-long
REFRESH_TOKEN_EXPIRY=30d

# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
PORT=3000
VITE_APP_ID=bdo-pearl-analysis-dev
APP_NAME=BDO Pearl Analysis
APP_VERSION=2.0.0-enterprise
APP_URL=http://localhost:5173

# ============================================
# CORS & SECURITY
# ============================================
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# SCRAPING & EXTERNAL SERVICES
# ============================================
GARMOTH_API_URL=https://garmoth.com
GARMOTH_TIMEOUT=30000
BDO_SHOP_URL=https://www.blackdesertbrazil.com/shop
SCRAPING_INTERVAL=0 0 * * 0
SCRAPING_RETRY_ATTEMPTS=3
SCRAPING_RETRY_DELAY=1000

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_DIR=./logs
ENABLE_FILE_LOGGING=true

# ============================================
# CACHE & PERFORMANCE
# ============================================
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=100
ENABLE_REDIS=false
REDIS_URL=redis://localhost:6379

# ============================================
# MONITORING & ANALYTICS
# ============================================
ENABLE_SENTRY=false
SENTRY_DSN=https://key@sentry.io/project
ENABLE_ANALYTICS=true

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_ADMIN_PANEL=true
ENABLE_SCRAPING=true
ENABLE_HISTORY=true
ENABLE_EXPORT=true
